---
import Logo from "./Logo.astro";

const navLinks = [
  { label: "Features", href: "#features" },
  { label: "How It Works", href: "#how-it-works" },
  { label: "Product", href: "#product-preview" },
  { label: "Pricing", href: "#pricing" },
  { label: "Testimonials", href: "#testimonials" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-neutral-950/60 backdrop-blur-xl supports-[backdrop-filter]:bg-neutral-950/50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 md:px-10">
    <a href="/" aria-label="FlowSpark home">
      <Logo />
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm text-neutral-300 transition hover:text-white">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a
        href="#"
        class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10"
      >
        Sign In
      </a>
      <a
        href="#"
        class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-emerald-400 to-blue-400 px-6 py-3 text-sm font-semibold text-neutral-950 transition hover:scale-[1.02] hover:shadow-lg hover:shadow-emerald-500/30"
      >
        Start Free
      </a>
    </div>

    <details class="relative md:hidden">
      <summary class="flex cursor-pointer list-none items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white marker:content-none">
        Menu
      </summary>

      <div class="absolute right-0 mt-3 w-64 rounded-2xl border border-white/10 bg-neutral-900/95 p-4 shadow-2xl shadow-black/40 backdrop-blur-xl">
        <nav class="flex flex-col gap-2">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="rounded-xl px-3 py-2 text-sm text-neutral-300 transition hover:bg-white/5 hover:text-white"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <div class="mt-4 grid gap-2 border-t border-white/10 pt-4">
          <a
            href="#"
            class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-center text-sm font-medium text-white transition hover:bg-white/10"
          >
            Sign In
          </a>
          <a
            href="#"
            class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-emerald-400 to-blue-400 px-6 py-3 text-sm font-semibold text-neutral-950 transition hover:scale-[1.02] hover:shadow-lg hover:shadow-emerald-500/30"
          >
            Start Free
          </a>
        </div>
      </div>
    </details>
  </div>
</header>

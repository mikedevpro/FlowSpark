---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class="flex items-center gap-3">
  <div class="relative flex h-10 w-10 items-center justify-center rounded-2xl border border-white/10 bg-white/5 shadow-lg shadow-emerald-500/10">
    <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-emerald-400/20 via-blue-400/10 to-violet-400/20"></div>
    <div class="relative h-5 w-5">
      <div class="absolute left-1/2 top-1/2 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-gradient-to-br from-emerald-400 to-blue-400 blur-[1px]"></div>
      <div class="absolute right-0 top-0 h-2.5 w-2.5 rotate-12 rounded-sm bg-white shadow-sm"></div>
    </div>
  </div>

  {!compact && (
    <div>
      <p class="text-base font-semibold tracking-tight text-white">FlowSpark</p>
      <p class="text-xs uppercase tracking-[0.18em] text-neutral-500">Workflow SaaS</p>
    </div>
  )}
</div>
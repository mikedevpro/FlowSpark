---
const brands = [
  "Northstar",
  "LumaCore",
  "Vertex Labs",
  "SummitOps",
  "BrightPath",
];
---

<section class="border-y border-white/10 bg-white/[0.02] px-6 py-12 md:px-12">
  <div class="mx-auto max-w-6xl">
    <div class="reveal text-center">
      <p class="text-xs font-medium uppercase tracking-[0.22em] text-neutral-500">
        Trusted by product teams, operators, and growing businesses
      </p>
    </div>

    <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-5">
      {brands.map((brand, index) => (
        <div
          class="reveal flex min-h-[72px] items-center justify-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-4 text-center text-sm font-semibold tracking-[0.18em] text-neutral-300 transition hover:border-white/20 hover:bg-white/[0.06] hover:text-white"
          style={`--delay: ${index * 100}ms;`}
        >
          <span class="h-2.5 w-2.5 rounded-full bg-gradient-to-br from-emerald-400 to-blue-400"></span>
          {brand}
        </div>
      ))}
    </div>

    <div class="mt-8 grid gap-4 border-t border-white/10 pt-8 text-center sm:grid-cols-2 lg:grid-cols-4">
      <div class="reveal rounded-2xl bg-white/[0.03] px-4 py-4" style="--delay: 80ms;">
        <p class="text-2xl font-semibold text-white">2,000+</p>
        <p class="mt-1 text-sm text-neutral-400">Growing teams</p>
      </div>

      <div class="reveal rounded-2xl bg-white/[0.03] px-4 py-4" style="--delay: 160ms;">
        <p class="text-2xl font-semibold text-white">99.9%</p>
        <p class="mt-1 text-sm text-neutral-400">Platform uptime</p>
      </div>

      <div class="reveal rounded-2xl bg-white/[0.03] px-4 py-4" style="--delay: 240ms;">
        <p class="text-2xl font-semibold text-white">4.9/5</p>
        <p class="mt-1 text-sm text-neutral-400">Average satisfaction</p>
      </div>

      <div class="reveal rounded-2xl bg-white/[0.03] px-4 py-4" style="--delay: 320ms;">
        <p class="text-2xl font-semibold text-white">10 min</p>
        <p class="mt-1 text-sm text-neutral-400">Average setup time</p>
      </div>
    </div>
  </div>
</section>

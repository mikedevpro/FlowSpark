---
const plans = [
  {
    name: "Starter",
    price: "Free",
    description: "For individuals and small workflows getting started.",
    features: [
      "Up to 2 projects",
      "Basic task tracking",
      "Shared workspace",
      "Email support",
    ],
    cta: "Start Free",
    featured: false,
  },
  {
    name: "Pro",
    price: "$19/mo",
    description: "For growing teams that need visibility and momentum.",
    features: [
      "Unlimited projects",
      "Timelines and dashboards",
      "Real-time collaboration",
      "Priority support",
    ],
    cta: "Choose Pro",
    featured: true,
  },
];
---

<section id="pricing" class="px-6 py-20 md:px-10">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl reveal">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-emerald-400">
        Simple pricing
      </p>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-5xl">
        Start free, scale when you're ready.
      </h2>
      <p class="mt-6 text-lg leading-8 text-neutral-300">
        Choose a plan that fits your workflow today, then grow into more advanced
        features as your team expands.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {plans.map((plan, index) => (
        <article
          class:list={[
            "rounded-[2rem] border p-8 shadow-2xl shadow-black/20",
            plan.featured
              ? "border-emerald-400/30 bg-gradient-to-br from-emerald-400/10 via-white/5 to-blue-400/10"
              : "border-white/10 bg-white/5",
          ]}
          style={`--delay: ${index * 140}ms;`}
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-2xl font-semibold text-white">{plan.name}</h3>
              <p class="mt-3 text-neutral-300">{plan.description}</p>
            </div>

            {plan.featured && (
              <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-medium text-emerald-300">
                Most Popular
              </span>
            )}
          </div>

          <div class="mt-8">
            <p class="text-4xl font-semibold tracking-tight text-white">{plan.price}</p>
          </div>

          <ul class="mt-8 space-y-4">
            {plan.features.map((feature) => (
              <li class="flex items-center gap-3 text-neutral-200">
                <span class="inline-block h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="#"
            class:list={[
              "mt-8 inline-flex w-full items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition hover:scale-[1.02]",
              plan.featured
                ? "bg-gradient-to-r from-emerald-400 to-blue-400 text-neutral-950 hover:shadow-lg hover:shadow-emerald-500/30"
                : "border border-white/15 bg-white/5 text-white hover:bg-white/10",
            ]}
          >
            {plan.cta}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

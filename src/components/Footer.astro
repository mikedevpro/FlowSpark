---
import Logo from "./Logo.astro";
--- 


<footer class="border-t border-white/10 px-6 py-10 md:px-10">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 md:flex-row md:items-start md:justify-between">
    <div class="max-w-sm">
      <Logo />
      <p class="mt-4 leading-7 text-neutral-400">
        A modern workflow platform for teams that want more clarity and less chaos.
      </p>
    </div>

    <nav>
      <ul class="grid gap-3 text-sm text-neutral-400">
        <li><a href="#product-preview" class="transition hover:text-white">Product</a></li>
        <li><a href="#features" class="transition hover:text-white">Features</a></li>
        <li><a href="#pricing" class="transition hover:text-white">Pricing</a></li>
        <li><a href="#product-preview" class="transition hover:text-white">Demo</a></li>
        <li><a href="#testimonials" class="transition hover:text-white">Contact</a></li>
      </ul>
    </nav>
  </div>

  <div class="mx-auto mt-10 max-w-6xl border-t border-white/10 pt-6 text-sm text-neutral-500">
    © 2026 FlowSpark. All rights reserved.
  </div>
</footer>